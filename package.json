{
  "name": "tripnest",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "start": "npm --prefix backend start",
    "dev": "npm --prefix backend run dev",
    "dev:online": "npm --prefix backend run dev:online",
    "mobile": "npm --prefix mobile start",
    "mobile:offline": "npm --prefix mobile run start -- --offline",
    "mobile:safe": "npm --prefix mobile run start -- --offline --port 8090",
    "mobile:phone": "powershell -ExecutionPolicy Bypass -Command \"$env:REACT_NATIVE_PACKAGER_HOSTNAME='172.20.10.2'; npm --prefix mobile run start -- --offline --host lan --port 8090 --clear\"",
    "mobile:ios": "npm --prefix mobile run ios",
    "mobile:android": "npm --prefix mobile run android",
    "mobile:run:android": "npm --prefix mobile run run:android",
    "mobile:typecheck": "npm --prefix mobile run typecheck",
    "tunnel": "powershell -ExecutionPolicy Bypass -File scripts/start-cloudflare-tunnel.ps1",
    "online-debug": "powershell -ExecutionPolicy Bypass -File scripts/start-online-debug.ps1"
  },
  "engines": {
    "node": ">=18"
  }
}
