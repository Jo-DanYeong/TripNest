<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/loginFragment">

    <fragment
        android:id="@+id/loginFragment"
        android:name="com.example.tripnest.LoginFragment"
        android:label="Login"
        tools:layout="@layout/fragment_login">

        <action
            android:id="@+id/action_loginFragment_to_homeFragment"
            app:destination="@id/homeFragment"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.example.tripnest.HomeFragment"
        android:label="Home"
        tools:layout="@layout/fragment_home">

        <action
            android:id="@+id/action_homeFragment_to_resultFragment"
            app:destination="@id/resultFragment" />

        <action
            android:id="@+id/action_homeFragment_to_mapPickFragment"
            app:destination="@id/mapPickFragment" />
    </fragment>
    <fragment
        android:id="@+id/resultFragment"
        android:name="com.example.tripnest.ResultFragment"
        android:label="Result"
        tools:layout="@layout/fragment_result">

        <action
            android:id="@+id/action_resultFragment_to_homeFragment"
            app:destination="@id/homeFragment" />

        <action
            android:id="@+id/action_resultFragment_to_mapPickFragment"
            app:destination="@id/mapPickFragment" />
    </fragment>

    <fragment
        android:id="@+id/mapPickFragment"
        android:name="com.example.tripnest.MapPickFragment"
        android:label="MapPick"
        tools:layout="@layout/fragment_map_pick" />

    <fragment
        android:id="@+id/myTripFragment"
        android:name="com.example.tripnest.MyTripFragment"
        android:label="MyTrip"
        tools:layout="@layout/fragment_my_trip" />
</navigation>
